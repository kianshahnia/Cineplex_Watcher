# Production environment template — Cinewatch (cinewatch.ca)
#
# Copy to `.env` ON THE SERVER ONLY (chmod 600). Never commit the real file.
# The same file is read twice: by docker compose for ${VAR} interpolation in
# docker-compose.prod.yml, and by the containers via `env_file:` (consumed by
# pydantic-settings, which matches names case-insensitively).

# --- Database ---
# The password appears in BOTH lines — keep them in sync. Generate with
# `openssl rand -hex 24` (hex avoids characters like / and @ that would break
# the URL).
POSTGRES_PASSWORD=<REPLACE_STRONG_PASSWORD>
DATABASE_URL=postgresql+asyncpg://postgres:<REPLACE_STRONG_PASSWORD>@postgres:5432/cineplex_watcher

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Generate with `openssl rand -hex 32`.
JWT_SECRET=<REPLACE_64_CHAR_RANDOM>
MAGIC_LINK_BASE_URL=https://cinewatch.ca/auth/verify

# --- Production toggles ---
CORS_ORIGINS=https://cinewatch.ca,https://www.cinewatch.ca
COOKIE_SECURE=true

# --- Admin ---
# Comma-separated emails allowed to hit /admin/* (the usage-metrics endpoint,
# GET /admin/stats). Matched case-insensitively against the signed-in user's
# email. LEAVE BLANK and no one has admin access (fail-closed); set your own
# login email to unlock it. You must be logged in AS one of these addresses.
ADMIN_EMAILS=<REPLACE_YOUR_LOGIN_EMAIL>

# --- Ops ---
LOG_JSON=true
# Safe behind Caddy (>=2.5 strips untrusted X-Forwarded-* headers).
RATE_LIMIT_TRUST_FORWARDED_FOR=true
# Poll-cycle dead-man's-switch. Create a check at healthchecks.io (free), paste
# its ping URL here. The Celery poller GETs it after every successful cycle; if
# pings stop (worker crashed/OOM'd), healthchecks emails you. Blank = disabled.
# This catches a dead poller that /health (API-only) can't see.
HEALTHCHECK_PING_URL=

# --- Email (Resend) ---
# REQUIRED in production: with an empty key, POST /auth/login returns the
# magic-link URL (the login token) in the response body — dev convenience,
# prod auth bypass. See docs/deployment.md Phase 3.3.
RESEND_API_KEY=<REPLACE_PRODUCTION_RESEND_KEY>
FROM_EMAIL=Cinewatch <alerts@cinewatch.ca>

# --- TMDB (landing-page "Now Playing" carousel) ---
# v4 Read Access Token (the long JWT). Blank = carousel falls back gracefully.
TMDB_API_TOKEN=<REPLACE_TMDB_V4_TOKEN>
TMDB_REGION=CA

# --- Deferred channels (leave blank at launch; blanks = log-and-skip) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=
